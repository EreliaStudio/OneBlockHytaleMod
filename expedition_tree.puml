' ─────────────────────────────────────────────
' PROGRESSION ARROWS  (A --> B = A drops unlock B)
' ─────────────────────────────────────────────

' From OneBlock / Meadow (IL1)
Meadow --> Plains         : Fibre+Soil_Dirt
Meadow --> Flower_Field   : Fibre+Grass
Meadow --> Farmland       : Soil_Dirt+Fibre
Meadow --> Forest         : Rubble_Stone+Fibre
Meadow --> Cactus_Field   : Fibre+Rubble_Stone
Meadow --> Desert         : Rubble_Stone+Fibre
Meadow --> Snow           : Rubble_Stone+Fibre

' IL2 -> IL3
Farmland  --> Garden      : Soil_Dirt+Wheat_Item
Plains    --> Garden      : Soil_Dirt
Plains    --> Forest      : Rubble_Stone
Plains    --> Flower_Field : Grass

' IL3 -> IL4
Forest      --> Autumn_Forest : Oak_Trunk+Fibre
Forest      --> Deep_Forest   : Oak_Trunk+Life_Essence
Forest      --> Tropical_Forest: Oak_Trunk+Fibre
Forest      --> Mushroom_Grove : Oak_Trunk+Soil_Dirt
Desert      --> Desert_Oasis  : Block_Sand+Rubble_Stone
Desert      --> Egyptian_Temple: Block_Sand+Sandstone
Desert      --> Desert_Ruins  : Block_Sand+Sandstone_Rough
Snow        --> Ice_Fields    : Block_Snow+Ice_Essence
Snow        --> Frozen_Forest : Block_Snow+Ice_Essence

' IL4 -> IL5
Plains      --> Cave          : Rubble_Stone+Life_Essence
Plains      --> Graveyard     : Soil_Dirt+Rubble_Stone
Plains      --> Swamp         : Soil_Dirt+Hay_Bundle
Farmland    --> Seed_Vault    : Wheat_Item+Corn_Item
Garden      --> Textile_Workshop: Cotton_Item+Fibre
Primal_Jungle --> Jungle      : Jungle_Trunk+Life_Essence
Primal_Jungle --> Poison_Grove: Jungle_Trunk+Life_Essence

' IL5 -> IL6
Cave        --> Gem_Cave      : Rock_Stone+Ore_Copper
Cave        --> Precious_Vein : Rock_Stone+Rock_Basalt
Cave        --> Deep_Cave     : Rock_Stone+Ore_Copper
Cave        --> Fungi_Cavern  : Mushroom_Block+Rock_Stone
Deep_Forest --> Redwood_Grove : Ash_Trunk+Tree_Bark
Deep_Forest --> Azure_Forest  : Ash_Trunk+Ice_Essence
Deep_Forest --> Storm_Wilds   : Ash_Trunk+Life_Essence
Ice_Fields  --> Frozen_Cave   : Ice_Clear+Ice_Essence
Graveyard   --> Ancient_Graveyard: Stone_Mossy+Bone_Fragment
Mushroom_Grove --> Fungi_Cavern: Mushroom_Block+Rock_Stone
Mushroom_Grove --> Glowing_Cavern: Mushroom_Block+Rock_Stone

' IL6 -> IL7
Azure_Forest --> Mystical_Forest: Azure_Trunk+Life_Essence
Redwood_Grove --> Ancient_Grove : Redwood_Trunk+Rock_Stone
Precious_Vein --> Deep_Mine     : Ore_Iron+Rock_Basalt
Deep_Cave   --> Deep_Mine       : Ore_Iron+Rock_Basalt
Dino_Caverns --> Amber_Dig      : Block_Amber+Rock_Volcanic
Seed_Vault  --> Mystic_Seeds    : Seeds_Wheat_Eternal+Life_Essence
Fungi_Cavern --> Glowing_Cavern : Mushroom_Block+Rock_Stone

' IL7 -> IL8
Dino_Caverns --> Inferno        : Rock_Volcanic+Fire_Essence
Deep_Cave   --> Inferno         : Rock_Volcanic+Fire_Essence
Deep_Mine   --> Abyssal_Mine    : Ore_Mithril+Void_Essence
Ancient_Graveyard --> Cursed_Crypt: Bone_Fragment+Void_Essence
Frozen_Cave --> Glacial_Depths  : Ice_Blue+Ice_Essence
Gem_Cave    --> Crystal_Depths  : Gem_Emerald+Rock_Basalt
Textile_Workshop --> Advanced_Textile: Bolt_Cotton+Bolt_Wool
Fiery_Forest --> Inferno        : Burnt_Trunk+Fire_Essence

' IL8 -> IL9
Inferno     --> Deep_Inferno    : Fire_Essence+Rock_Volcanic
Cursed_Crypt --> The_Abyss      : Void_Essence+Rock_Volcanic
Abyssal_Mine --> The_Abyss      : Void_Essence+Rock_Volcanic
Deep_Mine   --> Abyssal_Mine    : Ore_Mithril+Void_Essence

@enduml
